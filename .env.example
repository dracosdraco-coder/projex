# ─── Supabase ───────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used in OAuth callbacks, Stripe redirects, Twilio webhooks
NEXT_PUBLIC_APP_URL=https://projex.live

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products + prices in Stripe Dashboard
# Dashboard → Products → Add product → add Monthly + Annual prices for each plan
STRIPE_PRICE_DUO_MONTHLY=price_...
STRIPE_PRICE_DUO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# ─── SMTP / Email ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@projex.live
SMTP_PASS=your-smtp-password
SMTP_FROM=Projex <noreply@projex.live>

# ─── Twilio (VoIP + SMS) ─────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ─── Google OAuth (sign-in + Calendar integration) ───────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs:
#   https://[your-supabase-project].supabase.co/auth/v1/callback  ← for sign-in
#   https://projex.live/api/integrations/google/callback           ← for calendar
# Enable in Supabase → Auth → Providers → Google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── GitHub OAuth (sign-in) ───────────────────────────────────────────────────
# github.com → Settings → Developer settings → OAuth Apps → New OAuth App
# Callback URL: https://[your-supabase-project].supabase.co/auth/v1/callback
# Enable in Supabase → Auth → Providers → GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Google Ads Lead Webhook ─────────────────────────────────────────────────
# A secret string you define. Include in your webhook URL as ?key=THIS_VALUE
# Google Ads → Ads → Lead Forms → Webhook URL:
#   https://projex.live/api/integrations/google-ads/leads?org=YOUR_ORG_ID&key=THIS_VALUE
GOOGLE_ADS_WEBHOOK_KEY=your-secret-webhook-key

# ─── QuickBooks Integration ───────────────────────────────────────────────────
# developer.intuit.com → Dashboard → Keys & OAuth
# Redirect URI: https://projex.live/api/integrations/quickbooks/callback
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret
